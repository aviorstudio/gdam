---
import { getSessionFromCookies, hasAuthCookies } from '../lib/auth';
import { usernamesDto } from '../lib/dtoService';
import { supabase } from '../lib/supabase';
import Button from './Button.astro';

type UsernameRecord = {
	name: string | null;
};

type NavActionVariant = 'text' | 'icon' | 'primary';
type NavIconName = 'account' | 'docs' | 'key' | 'orgs' | 'sign-in';

type NavAction = {
	href: string;
	label: string;
	variant: NavActionVariant;
	icon?: NavIconName;
};

const session = hasAuthCookies(Astro.cookies) ? await getSessionFromCookies(Astro.cookies) : null;
const profileId = session?.user?.id ?? '';
const isSignedIn = Boolean(profileId);

let usernameDisplayForProfile = '';
let accountHref = '/';
if (profileId) {
	const { data: usernameRows, error: usernameError } = await usernamesDto.getByUserId(supabase, profileId);
	if (!usernameError) {
		const usernameRecord = ((usernameRows as UsernameRecord[] | null) ?? []).find((row) => row.name);
		usernameDisplayForProfile = usernameRecord?.name ?? '';
	}
}

if (usernameDisplayForProfile) {
	const usernamePath = `/@${encodeURIComponent(usernameDisplayForProfile)}`;
	accountHref = usernamePath;
}

const getIcon = (action: NavAction): NavIconName => {
	if (action.icon) return action.icon;
	if (action.label === 'Docs') return 'docs';
	return 'account';
};

const actions: NavAction[] = [
	{ href: '/docs', label: 'Docs', variant: 'text', icon: 'docs' },
	...(isSignedIn
		? usernameDisplayForProfile ? ([
				{ href: '/orgs', label: 'Orgs', variant: 'icon', icon: 'orgs' },
				{ href: accountHref, label: 'Account', variant: 'icon', icon: 'account' },
			] satisfies NavAction[])
			: ([
					{ href: '/register', label: 'Register username', variant: 'primary' },
				] satisfies NavAction[])
			: ([
					{ href: '/signin', label: 'Sign in', variant: 'primary', icon: 'sign-in' },
				] satisfies NavAction[])),
];
---

<nav
	class="relative z-10 mx-auto flex w-full max-w-5xl items-center gap-2 border-b border-slate-200 bg-white/80 px-4 py-4 backdrop-blur"
	aria-label="Primary"
>
	<a class="text-lg font-semibold tracking-tight text-slate-900 hover:text-slate-700" href="/">
		GDAM
	</a>

	{
		actions.map((action, index) => (
			<Button
				href={action.href}
				variant={action.variant === 'primary' ? 'primary' : 'outline'}
				icon={getIcon(action)}
				class={index === 0 ? 'ml-auto' : ''}
			>
				{action.label}
			</Button>
		))
	}
</nav>
