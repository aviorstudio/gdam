---
import Card from './Card.astro';

export type AddonListItem = {
  ownerLabel?: string;
  ownerHref?: string;
  addonLabel: string;
  addonHref?: string;
  metaLabel?: string;
  metaHref?: string;
  date?: string;
  deleteForm?: {
    label: string;
    fields: Record<string, string>;
    confirm?: string;
    csrfToken?: string;
  };
};

export type AddonListTone = 'muted' | 'error';

export type Props = {
  items: AddonListItem[];
  status?: string;
  tone?: AddonListTone;
  emptyTitle?: string;
  emptySubtitle?: string;
  hideBodyWhenError?: boolean;
};

const {
  items,
  status = '',
  tone = 'muted',
  emptyTitle = 'Nothing here yet',
  emptySubtitle = '',
  hideBodyWhenError = false,
} = Astro.props as Props;

const formatDate = (value?: string) => {
  if (!value) return '';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString();
};

const isExternalHref = (value?: string) => /^https?:\/\//i.test(value ?? '');

const shouldRenderBody = !(hideBodyWhenError && tone === 'error');
---

<Card class="flex flex-col gap-4">
  {status && (
    <p
      class:list={{
        'text-sm font-medium': true,
        'text-red-600': tone === 'error',
        'text-slate-600': tone !== 'error',
      }}
    >
      {status}
    </p>
  )}

  {
    shouldRenderBody
      ? items.length === 0 ? (
        <div class="flex flex-col gap-1 rounded-2xl border border-dashed border-slate-200 bg-slate-50 p-6 text-center">
          <p class="text-sm font-semibold text-slate-900">{emptyTitle}</p>
          {emptySubtitle && (
            <p class="text-sm text-slate-600">
              {emptySubtitle}
            </p>
          )}
        </div>
      ) : (
        <ul class="divide-y divide-slate-200">
          {
            items.map((item) => (
              <li class="flex flex-col gap-3 py-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="flex min-w-0 flex-col gap-1">
                  {item.ownerLabel ? (
                    <p class="break-words text-sm font-semibold text-slate-900">
                      {(item.ownerHref ? (
                        <a
                          class="text-slate-900 hover:underline"
                          href={item.ownerHref}
                          target={isExternalHref(item.ownerHref) ? '_blank' : undefined}
                          rel={isExternalHref(item.ownerHref) ? 'noopener noreferrer' : undefined}
                        >
                          {item.ownerLabel}
                        </a>
                      ) : (
                        <span class="text-slate-900">{item.ownerLabel}</span>
                      ))}<span class="text-slate-400">/</span>{(item.addonHref ? (
                        <a
                          class="text-slate-900 hover:underline"
                          href={item.addonHref}
                          target={isExternalHref(item.addonHref) ? '_blank' : undefined}
                          rel={isExternalHref(item.addonHref) ? 'noopener noreferrer' : undefined}
                        >
                          {item.addonLabel}
                        </a>
                      ) : (
                        <span class="text-slate-900">{item.addonLabel}</span>
                      ))}
                      {item.metaLabel && (
                        <>
                          {' '}
                          {item.metaHref ? (
                            <a
                              class="text-xs font-semibold text-slate-600 hover:underline"
                              href={item.metaHref}
                              target={isExternalHref(item.metaHref) ? '_blank' : undefined}
                              rel={isExternalHref(item.metaHref) ? 'noopener noreferrer' : undefined}
                            >
                              {item.metaLabel}
                            </a>
                          ) : (
                            <span class="text-xs font-semibold text-slate-600">{item.metaLabel}</span>
                          )}
                        </>
                      )}
                    </p>
                  ) : item.addonHref ? (
                    <a
                      class="break-words text-sm font-semibold text-slate-900 hover:underline"
                      href={item.addonHref}
                      target={isExternalHref(item.addonHref) ? '_blank' : undefined}
                      rel={isExternalHref(item.addonHref) ? 'noopener noreferrer' : undefined}
                    >
                      {item.addonLabel}
                    </a>
                  ) : (
                    <p class="break-words text-sm font-semibold text-slate-900">{item.addonLabel}</p>
                  )}

                  {item.metaLabel && !item.ownerLabel &&
                    (item.metaHref ? (
                      <a
                        class="text-xs font-semibold text-slate-600 hover:underline"
                        href={item.metaHref}
                        target={isExternalHref(item.metaHref) ? '_blank' : undefined}
                        rel={isExternalHref(item.metaHref) ? 'noopener noreferrer' : undefined}
                      >
                        {item.metaLabel}
                      </a>
                    ) : (
                      <p class="text-xs font-semibold text-slate-600">{item.metaLabel}</p>
                    ))}
                </div>
                {(item.date || item.deleteForm) && (
                  <div class="flex flex-wrap items-center gap-2 text-xs font-semibold">
                    {item.deleteForm && (
                      <form
                        method="post"
                        action={Astro.url.pathname}
                        onsubmit={item.deleteForm.confirm ? `return confirm(${JSON.stringify(item.deleteForm.confirm)})` : undefined}
                      >
                        {Object.entries(item.deleteForm.fields).map(([name, value]) => (
                          <input type="hidden" name={name} value={value} />
                        ))}
                        {item.deleteForm.csrfToken && <input type="hidden" name="csrf_token" value={item.deleteForm.csrfToken} />}
                        <button
                          class="rounded-full border border-red-200 bg-white px-3 py-1 font-semibold text-red-600 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500"
                          type="submit"
                          name="action"
                          value={item.deleteForm.fields.action}
                        >
                          {item.deleteForm.label}
                        </button>
                      </form>
                    )}
                    {item.date && (
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-slate-700">
                      <time datetime={item.date}>{formatDate(item.date)}</time>
                    </span>
                    )}
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      )
      : null
  }
</Card>
