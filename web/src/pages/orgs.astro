---
export const prerender = false;

import RootLayout from '../layouts/RootLayout.astro';
import Title from '../components/Title.astro';
import AddonList from '../components/AddonList.astro';
import { getSessionFromCookies } from '../lib/auth';
import { orgsProfilesDto, usernamesDto } from '../lib/dtoService';
import { supabase } from '../lib/supabase';

type UsernameRecord = {
  name: string | null;
  user_id: string | null;
  org_id: string | null;
};

type OrgsProfileRecord = {
  org_id: string | null;
  admin: boolean | null;
  created_at: string | null;
};

const session = await getSessionFromCookies(Astro.cookies);
if (!session) {
  return Astro.redirect('/');
}

const profileId = session.user?.id ?? '';
if (!profileId) {
  return Astro.redirect('/');
}

const { data: usernameRows } = await usernamesDto.getByUserId(supabase, profileId);
const usernameRecord = ((usernameRows as UsernameRecord[] | null) ?? []).find((row) => row.name);
const usernameDisplay = usernameRecord?.name ?? '';

let status = '';
let tone: 'muted' | 'error' = 'muted';
let orgItems: Array<{
  addonLabel: string;
  addonHref?: string;
  metaLabel?: string;
  date?: string;
}> = [];

const { data: membershipRows, error: membershipError } = await orgsProfilesDto.listByProfileId(supabase, profileId);
if (membershipError) {
  status = membershipError.message;
  tone = 'error';
} else {
  const memberships = (membershipRows as OrgsProfileRecord[] | null) ?? [];
  const orgIds = Array.from(new Set(memberships.map((row) => row.org_id).filter(Boolean) as string[]));

  const usernameByOrgId = new Map<string, string>();
  if (orgIds.length > 0) {
    const { data: orgUsernameRows, error: usernameListError } = await usernamesDto.listByOrgIds(supabase, orgIds);
    if (usernameListError) {
      status = usernameListError.message;
      tone = 'error';
    } else {
      for (const row of (orgUsernameRows as UsernameRecord[] | null) ?? []) {
        if (!row.org_id || !row.name) continue;
        if (!usernameByOrgId.has(row.org_id)) {
          usernameByOrgId.set(row.org_id, row.name);
        }
      }
    }
  }

  orgItems = memberships
    .filter((membership) => membership.org_id)
    .map((membership) => {
      const orgId = membership.org_id as string;
      const orgUsername = usernameByOrgId.get(orgId) ?? '';
      const orgLabel = orgUsername ? `@${orgUsername}` : orgId;
      const orgHref = orgUsername ? `/@${encodeURIComponent(orgUsername)}` : undefined;
      return {
        addonLabel: orgLabel,
        addonHref: orgHref,
        metaLabel: membership.admin ? 'Admin' : 'Member',
        date: membership.created_at ?? undefined,
      };
    });
}
---

<RootLayout>
  <Title
    title="Orgs"
    subtitle={usernameDisplay ? `Organizations for @${usernameDisplay}.` : 'Your organizations.'}
    action={{ href: '/orgs/create', label: 'Create org' }}
  />

  <AddonList
    items={orgItems}
    status={status}
    tone={tone}
    hideBodyWhenError
    emptyTitle="No orgs yet"
    emptySubtitle="Create an org to publish addons under a shared account."
  />

</RootLayout>
