---
export const prerender = false;

import RootLayout from '../layouts/RootLayout.astro';
import AuthForm from '../components/AuthForm.astro';
import Input from '../components/Input.astro';
import Splash from '../components/Splash.astro';
import { getSessionFromCookies, hasAuthCookies } from '../lib/auth';

const session = hasAuthCookies(Astro.cookies) ? await getSessionFromCookies(Astro.cookies) : null;
if (session?.user?.id) {
	return Astro.redirect('/');
}
---

<RootLayout>
	<Splash />
	<AuthForm mode="signin">
		<Input label="Email" name="email" type="email" autocomplete="email" />
		<Input label="Password" name="password" type="password" autocomplete="current-password" />
	</AuthForm>
</RootLayout>
