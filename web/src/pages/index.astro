---
export const prerender = false;

import RootLayout from '../layouts/RootLayout.astro';
import Splash from '../components/Splash.astro';
import Title from '../components/Title.astro';
import AddonList from '../components/AddonList.astro';
import { addonVersionsDto, addonsDto, usernamesDto } from '../lib/dtoService';
import { toRepoUrl } from '../lib/repo';
import { formatSemverTripletFromNullable } from '../lib/semver';
import { supabase } from '../lib/supabase';

type AddonRecord = {
  id: string;
  name: string | null;
  repo: string | null;
  created_at: string | null;
  user_id: string | null;
  org_id: string | null;
};

type AddonVersionRecord = {
  addon_id: string;
  major: number | null;
  minor: number | null;
  patch: number | null;
  tag: string | null;
  created_at: string | null;
};

type UsernameRecord = {
  name: string | null;
  user_id: string | null;
  org_id: string | null;
};

let addonsStatus = '';

const { data: addonsData, error: addonsError } = await addonsDto.listAll(supabase);
if (addonsError) addonsStatus = addonsError.message;

const addons = (addonsData as AddonRecord[] | null) ?? [];

const latestReleaseByAddonId = new Map<string, { version: string; releaseTag: string; createdAt: string }>();
if (addons.length > 0) {
  const addonIds = addons.map((addon) => addon.id);
  const { data: versionRows, error: versionError } = await addonVersionsDto.listByAddonIds(supabase, addonIds);
  if (!versionError) {
    for (const row of (versionRows as AddonVersionRecord[] | null) ?? []) {
      if (!latestReleaseByAddonId.has(row.addon_id)) {
        latestReleaseByAddonId.set(row.addon_id, {
          version: formatSemverTripletFromNullable(row),
          releaseTag: row.tag ?? '',
          createdAt: row.created_at ?? '',
        });
      }
    }
  }
}

const userIds = Array.from(new Set(addons.map((addon) => addon.user_id).filter(Boolean) as string[]));
const orgIds = Array.from(new Set(addons.map((addon) => addon.org_id).filter(Boolean) as string[]));

const usernameByUserId = new Map<string, string>();
if (userIds.length > 0) {
  const { data: usernameRows, error: usernameError } = await usernamesDto.listByUserIds(supabase, userIds);
  if (!usernameError) {
    for (const row of (usernameRows as UsernameRecord[] | null) ?? []) {
      if (!row.user_id || !row.name) continue;
      if (!usernameByUserId.has(row.user_id)) {
        usernameByUserId.set(row.user_id, row.name);
      }
    }
  }
}

const usernameByOrgId = new Map<string, string>();
if (orgIds.length > 0) {
  const { data: usernameRows, error: usernameError } = await usernamesDto.listByOrgIds(supabase, orgIds);
  if (!usernameError) {
    for (const row of (usernameRows as UsernameRecord[] | null) ?? []) {
      if (!row.org_id || !row.name) continue;
      if (!usernameByOrgId.has(row.org_id)) {
        usernameByOrgId.set(row.org_id, row.name);
      }
    }
  }
}

const addonList = addons.map((addon) => {
  const ownerDisplay = addon.user_id
    ? usernameByUserId.get(addon.user_id) ?? ''
    : addon.org_id
      ? usernameByOrgId.get(addon.org_id) ?? ''
      : '';
  const ownerPath = ownerDisplay ? `/@${encodeURIComponent(ownerDisplay)}` : '';
  const addonSlug = addon.name ?? '';
  const addonPath = ownerDisplay && addonSlug ? `${ownerPath}/${encodeURIComponent(addonSlug)}` : '';
  const latestRelease = latestReleaseByAddonId.get(addon.id);
  const repoUrl = addon.repo ? toRepoUrl(addon.repo) : '';
  const versionLabel = latestRelease?.version ? latestRelease.version : 'No versions';
  const treeUrl = latestRelease?.releaseTag ? `${repoUrl}/releases/tag/${encodeURIComponent(latestRelease.releaseTag)}` : '';

  return {
    ownerLabel: ownerDisplay ? `@${ownerDisplay}` : undefined,
    ownerHref: ownerPath || undefined,
    addonLabel: addonSlug || 'Untitled addon',
    addonHref: addonPath || undefined,
    metaLabel: versionLabel,
    metaHref: treeUrl || undefined,
    date: latestRelease?.createdAt || addon.created_at || '',
  };
});
---

<RootLayout>
  <Splash title="Godot Addon Manager" subtitle="Addons simplified" />
  <Title title="All addons" subtitle="Browse all addons" />
  <AddonList
    items={addonList}
    status={addonsStatus}
    tone={addonsStatus ? 'error' : 'muted'}
    emptyTitle="No addons yet"
    emptySubtitle="Be the first to publish a Godot add-on."
  />
</RootLayout>
