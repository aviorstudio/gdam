---
export const prerender = false;

import RootLayout from '../../layouts/RootLayout.astro';
import Title from '../../components/Title.astro';
import AddonList from '../../components/AddonList.astro';
import { getSessionFromCookies, hasAuthCookies } from '../../lib/auth';
import { orgsProfilesDto, releasesDto, addonsDto, usernamesDto } from '../../lib/dtoService';
import { toGitHubRepoRootUrl, toRepoUrl } from '../../lib/repo';
import { formatSemverTripletFromNullable } from '../../lib/semver';
import { supabase } from '../../lib/supabase';

const DELETE_CSRF_COOKIE = 'gdam-delete-csrf';

type UsernameRecord = {
  name: string | null;
  user_id: string | null;
  org_id: string | null;
};

type OrgsProfileRecord = {
  admin: boolean | null;
};

type AddonRecord = {
  id: string;
  name: string | null;
  repo: string | null;
  editor?: boolean | null;
  created_at: string | null;
};

type ReleaseRecord = {
  addon_id: string | null;
  major: number | null;
  minor: number | null;
  patch: number | null;
  tag: string | null;
  asset: string | null;
  created_at: string | null;
};

const safeDecodeURIComponent = (value: string) => {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const normalizeUsername = (value: string) => value.trim().toLowerCase();

const usernameParamRaw = Astro.params.username ?? '';
const usernameParam = safeDecodeURIComponent(usernameParamRaw);
const usernameNormal = normalizeUsername(usernameParam);

const addonParamRaw = Astro.params.addon ?? '';
const addonName = safeDecodeURIComponent(addonParamRaw).trim();

const session = hasAuthCookies(Astro.cookies) ? await getSessionFromCookies(Astro.cookies) : null;
const profileId = session?.user?.id ?? '';
let deleteCsrfToken = Astro.cookies.get(DELETE_CSRF_COOKIE)?.value ?? '';
if (!deleteCsrfToken) {
  deleteCsrfToken = crypto.randomUUID();
  Astro.cookies.set(DELETE_CSRF_COOKIE, deleteCsrfToken, { path: '/', sameSite: 'lax', secure: Astro.url.protocol === 'https:' });
}

let pageTone: 'default' | 'not-found' | 'error' = 'default';
let pageStatus = '';
let ownerLabel = '';
let ownerSlug = encodeURIComponent(usernameParam);

let canCreateRelease = false;

let addon: {
  id: string;
  name: string;
  repo: string;
  editorPlugin: boolean;
  createdAt: string;
} | null = null;

let versions: Array<{
  version: string;
  major: number;
  minor: number;
  patch: number;
  releaseTag: string;
  assetName: string;
  createdAt: string;
}> = [];

const notFound = () => {
  Astro.response.status = 404;
  pageTone = 'not-found';
  pageStatus = 'That addon could not be found.';
};

if (!usernameNormal || !addonName) {
  notFound();
} else {
  const { data: usernameRow, error: usernameError } = await usernamesDto.getByName(supabase, usernameNormal);

  if (usernameError) {
    Astro.response.status = 500;
    pageTone = 'error';
    pageStatus = usernameError.message;
  } else if (!usernameRow) {
    notFound();
  } else {
    const usernameRecord = usernameRow as UsernameRecord;
    const usernameDisplay = usernameRecord.name || usernameParam;
    ownerLabel = `@${usernameDisplay}`;
    ownerSlug = encodeURIComponent(usernameDisplay);

    const ownerProfileId = usernameRecord.user_id;
    const ownerOrgId = usernameRecord.org_id;

    let canPublishForOrg = false;
    if (ownerOrgId && profileId) {
      const { data: membershipRow, error: membershipError } = await orgsProfilesDto.getByOrgIdAndProfileId(
        supabase,
        ownerOrgId,
        profileId
      );
      if (!membershipError && membershipRow) {
        const membershipRecord = membershipRow as OrgsProfileRecord;
        canPublishForOrg = Boolean(membershipRecord.admin);
      }
    }

    canCreateRelease = Boolean(
      (ownerProfileId && profileId && ownerProfileId === profileId) ||
      (ownerOrgId && canPublishForOrg)
    );

    if (ownerProfileId && ownerOrgId) {
      Astro.response.status = 500;
      pageTone = 'error';
      pageStatus = 'Username is assigned to multiple owners.';
    } else if (!ownerProfileId && !ownerOrgId) {
      notFound();
    } else {
      const { data: addonRow, error: addonError } = ownerOrgId
        ? await addonsDto.getByOrgIdAndName(supabase, ownerOrgId, addonName)
        : await addonsDto.getByProfileIdAndName(supabase, ownerProfileId ?? '', addonName);

      if (addonError) {
        Astro.response.status = 500;
        pageTone = 'error';
        pageStatus = addonError.message;
      } else if (!addonRow) {
        notFound();
      } else {
        const addonRecord = addonRow as AddonRecord;

        addon = {
          id: addonRecord.id,
          name: addonRecord.name ?? addonName,
          repo: addonRecord.repo ?? '',
          editorPlugin: Boolean(addonRecord.editor),
          createdAt: addonRecord.created_at ?? '',
        };

        if (Astro.request.method === 'POST') {
          if (!session || !profileId) {
            return Astro.redirect('/signin');
          }

          const formData = await Astro.request.formData();
          const action = String(formData.get('action') ?? '');

          if (!canCreateRelease) {
            Astro.response.status = 403;
            pageTone = 'error';
            pageStatus = 'You do not have permission to manage releases for this addon.';
          } else if (action === 'delete-addon') {
            if (String(formData.get('csrf_token') ?? '') !== deleteCsrfToken) {
              Astro.response.status = 403;
              pageTone = 'error';
              pageStatus = 'Invalid delete request.';
            } else {
            const { error: deleteError } = await addonsDto.deleteById(supabase, addon.id);
            if (deleteError) {
              Astro.response.status = 500;
              pageTone = 'error';
              pageStatus = deleteError.message;
            } else {
              return Astro.redirect(`/@${ownerSlug}`);
            }
            }
          } else if (action === 'delete-version') {
            const major = Number(String(formData.get('major') ?? ''));
            const minor = Number(String(formData.get('minor') ?? ''));
            const patch = Number(String(formData.get('patch') ?? ''));
            if (String(formData.get('csrf_token') ?? '') !== deleteCsrfToken) {
              Astro.response.status = 403;
              pageTone = 'error';
              pageStatus = 'Invalid delete request.';
            } else if (!Number.isInteger(major) || !Number.isInteger(minor) || !Number.isInteger(patch)) {
              Astro.response.status = 400;
              pageTone = 'error';
              pageStatus = 'Invalid version selected.';
            } else {
              const { error: deleteError } = await releasesDto.deleteByVersion(supabase, addon.id, major, minor, patch);
              if (deleteError) {
                Astro.response.status = 500;
                pageTone = 'error';
                pageStatus = deleteError.message;
              } else {
                return Astro.redirect(Astro.url.pathname);
              }
            }
          }
        }

        const { data: versionRows, error: versionError } = await releasesDto.listByAddonId(supabase, addon.id);
        if (versionError) {
          Astro.response.status = 500;
          pageTone = 'error';
          pageStatus = versionError.message;
        } else {
          versions = ((versionRows as ReleaseRecord[] | null) ?? [])
            .map((row) => ({
              version: formatSemverTripletFromNullable(row),
              major: row.major ?? -1,
              minor: row.minor ?? -1,
              patch: row.patch ?? -1,
              releaseTag: row.tag ?? '',
              assetName: row.asset ?? '',
              createdAt: row.created_at ?? '',
            }));
        }
      }
    }
  }
}

const ownerPath = `/@${ownerSlug}`;
const repoUrl = addon?.repo ? toGitHubRepoRootUrl(addon.repo) || toRepoUrl(addon.repo) : '';
const repoLabel = repoUrl ? repoUrl.replace(/^https?:\/\//i, '') : '';
const versionList = versions.map((version) => ({
  addonLabel: version.version || 'Unknown version',
  addonHref: version.releaseTag ? `${repoUrl}/releases/tag/${encodeURIComponent(version.releaseTag)}` : undefined,
  date: version.createdAt,
  deleteForm: canCreateRelease && version.major >= 0 && version.minor >= 0 && version.patch >= 0 ? {
    label: 'Delete',
    fields: {
      action: 'delete-version',
      major: String(version.major),
      minor: String(version.minor),
      patch: String(version.patch),
    },
    confirm: `Delete version ${version.version}?`,
    csrfToken: deleteCsrfToken,
  } : undefined,
}));
---

<RootLayout>
  <Title
    title={pageTone === 'not-found' ? 'Not found' : undefined}
    titleParts={pageTone !== 'not-found'
      ? [
          { label: ownerLabel || `@${usernameParam}`, href: ownerPath },
          { label: addon?.name || addonName },
        ]
      : undefined}
    subtitle={pageTone === 'not-found'
      ? 'No addon matches that URL.'
      : undefined}
    subtitleLink={pageTone !== 'not-found' && repoUrl
      ? { href: repoUrl, label: repoLabel || addon?.repo || repoUrl, external: true }
      : undefined}
    actions={canCreateRelease && pageTone === 'default' && addon ? [
      { href: `/publish/@${ownerSlug}/${encodeURIComponent(addon.name || addonName)}`, label: 'Publish release' },
      { href: `/settings/@${ownerSlug}/${encodeURIComponent(addon.name || addonName)}`, label: 'Settings' },
    ] : undefined}
  />

  <AddonList
    items={versionList}
    status={pageStatus}
    tone={pageTone === 'error' ? 'error' : 'muted'}
    hideBodyWhenError
    emptyTitle={pageTone === 'not-found' ? 'No matching addon' : 'No versions yet'}
    emptySubtitle={pageTone === 'not-found'
      ? 'Double-check the URL and try again.'
      : 'This addon has not published any versions.'}
  />
</RootLayout>
