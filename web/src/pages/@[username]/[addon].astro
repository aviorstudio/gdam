---
export const prerender = false;

import RootLayout from '../../layouts/RootLayout.astro';
import Dialog from '../../components/Dialog.astro';
import Title from '../../components/Title.astro';
import AddonList from '../../components/AddonList.astro';
import Input from '../../components/Input.astro';
import { getSessionFromCookies, hasAuthCookies } from '../../lib/auth';
import { orgsProfilesDto, addonVersionsDto, addonsDto, usernamesDto } from '../../lib/dtoService';
import { findGitHubReleaseTag, releaseHasAsset, releaseTagCandidates } from '../../lib/github';
import { parseGitHubOwnerRepo, toGitHubRepoRootUrl, toRepoUrl } from '../../lib/repo';
import { formatSemverTripletFromNullable, parseSemverTriplet } from '../../lib/semver';
import { supabase } from '../../lib/supabase';

const DELETE_CSRF_COOKIE = 'gdam-delete-csrf';

type UsernameRecord = {
  username_display: string | null;
  user_id: string | null;
  org_id: string | null;
};

type OrgsProfileRecord = {
  admin: boolean | null;
};

type AddonRecord = {
  id: string;
  name: string | null;
  repo: string | null;
  editor_plugin?: boolean | null;
  created_at: string | null;
};

type AddonVersionRecord = {
  addon_id: string | null;
  major: number | null;
  minor: number | null;
  patch: number | null;
  tag: string | null;
  asset: string | null;
  created_at: string | null;
};

const safeDecodeURIComponent = (value: string) => {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const normalizeUsername = (value: string) => value.trim().toLowerCase();

const usernameParamRaw = Astro.params.username ?? '';
const usernameParam = safeDecodeURIComponent(usernameParamRaw);
const usernameNormal = normalizeUsername(usernameParam);

const addonParamRaw = Astro.params.addon ?? '';
const addonName = safeDecodeURIComponent(addonParamRaw).trim();

const session = hasAuthCookies(Astro.cookies) ? await getSessionFromCookies(Astro.cookies) : null;
const profileId = session?.user?.id ?? '';
let deleteCsrfToken = Astro.cookies.get(DELETE_CSRF_COOKIE)?.value ?? '';
if (!deleteCsrfToken) {
  deleteCsrfToken = crypto.randomUUID();
  Astro.cookies.set(DELETE_CSRF_COOKIE, deleteCsrfToken, { path: '/', sameSite: 'lax', secure: Astro.url.protocol === 'https:' });
}

let pageTone: 'default' | 'not-found' | 'error' = 'default';
let pageStatus = '';
let ownerLabel = '';
let ownerSlug = encodeURIComponent(usernameParam);

let canCreateRelease = false;
let showCreateReleaseDialog = Astro.url.searchParams.get('create') === '1';
let createStatus = '';
let createTone: 'muted' | 'error' | 'success' = 'muted';

let formVersion = '';
let formReleaseTag = '';
let formAssetName = '';

if (showCreateReleaseDialog && !session) {
  return Astro.redirect('/signin');
}

let addon: {
  id: string;
  name: string;
  repo: string;
  editorPlugin: boolean;
  createdAt: string;
} | null = null;

let versions: Array<{
  version: string;
  major: number;
  minor: number;
  patch: number;
  releaseTag: string;
  assetName: string;
  createdAt: string;
}> = [];

const defaultAssetName = (owner: string, repo: string) => `@${owner}_${repo}.zip`;

const notFound = () => {
  Astro.response.status = 404;
  pageTone = 'not-found';
  pageStatus = 'That addon could not be found.';
};

if (!usernameNormal || !addonName) {
  notFound();
} else {
  const { data: usernameRow, error: usernameError } = await usernamesDto.getByUsernameNormal(supabase, usernameNormal);

  if (usernameError) {
    Astro.response.status = 500;
    pageTone = 'error';
    pageStatus = usernameError.message;
  } else if (!usernameRow) {
    notFound();
  } else {
    const usernameRecord = usernameRow as UsernameRecord;
    const usernameDisplay = usernameRecord.username_display || usernameParam;
    ownerLabel = `@${usernameDisplay}`;
    ownerSlug = encodeURIComponent(usernameDisplay);

    const ownerProfileId = usernameRecord.user_id;
    const ownerOrgId = usernameRecord.org_id;

    let canPublishForOrg = false;
    if (ownerOrgId && profileId) {
      const { data: membershipRow, error: membershipError } = await orgsProfilesDto.getByOrgIdAndProfileId(
        supabase,
        ownerOrgId,
        profileId
      );
      if (!membershipError && membershipRow) {
        const membershipRecord = membershipRow as OrgsProfileRecord;
        canPublishForOrg = Boolean(membershipRecord.admin);
      }
    }

    canCreateRelease = Boolean(
      (ownerProfileId && profileId && ownerProfileId === profileId) ||
      (ownerOrgId && canPublishForOrg)
    );

    if (showCreateReleaseDialog && !canCreateRelease) {
      Astro.response.status = 403;
      pageTone = 'error';
      pageStatus = 'You do not have permission to publish releases for this addon.';
      showCreateReleaseDialog = false;
    }

    if (ownerProfileId && ownerOrgId) {
      Astro.response.status = 500;
      pageTone = 'error';
      pageStatus = 'Username is assigned to multiple owners.';
    } else if (!ownerProfileId && !ownerOrgId) {
      notFound();
    } else {
      const { data: addonRow, error: addonError } = ownerOrgId
        ? await addonsDto.getByOrgIdAndName(supabase, ownerOrgId, addonName)
        : await addonsDto.getByUserIdAndName(supabase, ownerProfileId ?? '', addonName);

      if (addonError) {
        Astro.response.status = 500;
        pageTone = 'error';
        pageStatus = addonError.message;
      } else if (!addonRow) {
        notFound();
      } else {
        const addonRecord = addonRow as AddonRecord;

        addon = {
          id: addonRecord.id,
          name: addonRecord.name ?? addonName,
          repo: addonRecord.repo ?? '',
          editorPlugin: Boolean(addonRecord.editor_plugin),
          createdAt: addonRecord.created_at ?? '',
        };

        if (Astro.request.method === 'POST') {
          if (!session || !profileId) {
            return Astro.redirect('/signin');
          }

          const formData = await Astro.request.formData();
          const action = String(formData.get('action') ?? 'create-release');

          if (!canCreateRelease) {
            Astro.response.status = 403;
            pageTone = 'error';
            createStatus = 'You do not have permission to publish releases for this addon.';
            createTone = 'error';
          } else if (action === 'delete-addon') {
            if (String(formData.get('csrf_token') ?? '') !== deleteCsrfToken) {
              Astro.response.status = 403;
              pageTone = 'error';
              pageStatus = 'Invalid delete request.';
            } else {
            const { error: deleteError } = await addonsDto.deleteById(supabase, addon.id);
            if (deleteError) {
              Astro.response.status = 500;
              pageTone = 'error';
              pageStatus = deleteError.message;
            } else {
              return Astro.redirect(`/@${ownerSlug}`);
            }
            }
          } else if (action === 'delete-version') {
            const major = Number(String(formData.get('major') ?? ''));
            const minor = Number(String(formData.get('minor') ?? ''));
            const patch = Number(String(formData.get('patch') ?? ''));
            if (String(formData.get('csrf_token') ?? '') !== deleteCsrfToken) {
              Astro.response.status = 403;
              pageTone = 'error';
              pageStatus = 'Invalid delete request.';
            } else if (!Number.isInteger(major) || !Number.isInteger(minor) || !Number.isInteger(patch)) {
              Astro.response.status = 400;
              pageTone = 'error';
              pageStatus = 'Invalid version selected.';
            } else {
              const { error: deleteError } = await addonVersionsDto.deleteByVersion(supabase, addon.id, major, minor, patch);
              if (deleteError) {
                Astro.response.status = 500;
                pageTone = 'error';
                pageStatus = deleteError.message;
              } else {
                return Astro.redirect(Astro.url.pathname);
              }
            }
          } else {
            showCreateReleaseDialog = true;
            formVersion = String(formData.get('version') ?? '').trim();
            formReleaseTag = String(formData.get('tag') ?? '').trim();
            formAssetName = String(formData.get('asset') ?? '').trim();

            if (!formVersion) {
              createStatus = 'Version is required.';
              createTone = 'error';
            } else {
              const versionTriplet = parseSemverTriplet(formVersion);
              if (!versionTriplet) {
                createStatus = 'Version must be in MAJOR.MINOR.PATCH format.';
                createTone = 'error';
              } else {
                const githubRepo = parseGitHubOwnerRepo(addon.repo);
                if (!githubRepo) {
                  createStatus = 'Only GitHub repositories are supported (github.com/owner/repo).';
                  createTone = 'error';
                } else {
                  const releaseLookup = await findGitHubReleaseTag(
                    githubRepo.owner,
                    githubRepo.repo,
                    releaseTagCandidates(formVersion, formReleaseTag)
                  );
                  if (!releaseLookup.tag) {
                    createStatus = releaseLookup.error ?? 'Matching GitHub Release was not found.';
                    createTone = 'error';
                  } else {
                    formReleaseTag = releaseLookup.tag;
                    if (!formAssetName) formAssetName = defaultAssetName(githubRepo.owner, githubRepo.repo);
                    const assetLookup = await releaseHasAsset(githubRepo.owner, githubRepo.repo, formReleaseTag, formAssetName);
                    if (!assetLookup.ok) {
                      createStatus = assetLookup.error ?? 'Matching GitHub Release asset was not found.';
                      createTone = 'error';
                    } else {
                      const { error: versionError } = await addonVersionsDto.insert(supabase, {
                        addon_id: addon.id,
                        major: versionTriplet.major,
                        minor: versionTriplet.minor,
                        patch: versionTriplet.patch,
                        tag: formReleaseTag,
                        asset: formAssetName,
                      });

                      if (versionError) {
                        createStatus = versionError.message;
                        createTone = 'error';
                      } else {
                        return Astro.redirect(Astro.url.pathname);
                      }
                    }
                  }
                }
              }
            }
          }
        }

        const { data: versionRows, error: versionError } = await addonVersionsDto.listByAddonId(supabase, addon.id);
        if (versionError) {
          Astro.response.status = 500;
          pageTone = 'error';
          pageStatus = versionError.message;
        } else {
          versions = ((versionRows as AddonVersionRecord[] | null) ?? [])
            .map((row) => ({
              version: formatSemverTripletFromNullable(row),
              major: row.major ?? -1,
              minor: row.minor ?? -1,
              patch: row.patch ?? -1,
              releaseTag: row.tag ?? '',
              assetName: row.asset ?? '',
              createdAt: row.created_at ?? '',
            }));
        }
      }
    }
  }
}

const ownerPath = `/@${ownerSlug}`;
const repoUrl = addon?.repo ? toGitHubRepoRootUrl(addon.repo) || toRepoUrl(addon.repo) : '';
const repoLabel = repoUrl ? repoUrl.replace(/^https?:\/\//i, '') : '';
const versionList = versions.map((version) => ({
  addonLabel: version.version || 'Unknown version',
  addonHref: version.releaseTag ? `${repoUrl}/releases/tag/${encodeURIComponent(version.releaseTag)}` : undefined,
  date: version.createdAt,
  deleteForm: canCreateRelease && version.major >= 0 && version.minor >= 0 && version.patch >= 0 ? {
    label: 'Delete',
    fields: {
      action: 'delete-version',
      major: String(version.major),
      minor: String(version.minor),
      patch: String(version.patch),
    },
    confirm: `Delete version ${version.version}?`,
    csrfToken: deleteCsrfToken,
  } : undefined,
}));
---

<RootLayout>
  <Title
    title={pageTone === 'not-found' ? 'Not found' : undefined}
    titleParts={pageTone !== 'not-found'
      ? [
          { label: ownerLabel || `@${usernameParam}`, href: ownerPath },
          { label: addon?.name || addonName },
        ]
      : undefined}
    subtitle={pageTone === 'not-found'
      ? 'No addon matches that URL.'
      : repoUrl ? (addon?.editorPlugin ? 'Editor plugin' : 'Runtime addon') : 'No repository linked.'}
    subtitleLink={pageTone !== 'not-found' && repoUrl
      ? { href: repoUrl, label: repoLabel || addon?.repo || repoUrl, external: true }
      : undefined}
    action={canCreateRelease && pageTone === 'default' ? { href: '?create=1', label: 'Create release' } : undefined}
  />

  <AddonList
    items={versionList}
    status={pageStatus}
    tone={pageTone === 'error' ? 'error' : 'muted'}
    hideBodyWhenError
    emptyTitle={pageTone === 'not-found' ? 'No matching addon' : 'No versions yet'}
    emptySubtitle={pageTone === 'not-found'
      ? 'Double-check the URL and try again.'
      : 'This addon has not published any versions.'}
  />

  {
    canCreateRelease && (
      <Dialog id="create-release-dialog" open={showCreateReleaseDialog} title="Create a release" size="lg">
        <Fragment slot="description">
          Publish a new release for this addon.
        </Fragment>

	        <form method="post" action={Astro.url.pathname} class="flex flex-col gap-4">
	          <div class="grid gap-4 md:grid-cols-2">
	            <Input
	              label="Version"
	              name="version"
	              placeholder="0.1.0"
	              type="text"
	              value={formVersion}
	              required
	            />

	            <Input
	              label="Release tag (optional)"
	              name="tag"
	              placeholder="v0.1.0"
	              type="text"
	              value={formReleaseTag}
	            />

	            <Input
	              label="Asset name"
	              name="asset"
	              placeholder="@owner_repo.zip"
	              type="text"
	              value={formAssetName}
	            />
	          </div>

          <p
            class:list={{
              'min-h-[20px] text-sm': true,
              'text-slate-500': createTone === 'muted',
              'text-red-600': createTone === 'error',
              'text-green-600': createTone === 'success',
            }}
          >
            {createStatus}
          </p>

          <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a
              class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400"
              href={Astro.url.pathname}
            >
              Cancel
            </a>
            <button
              class="inline-flex items-center justify-center rounded-xl bg-sky-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600"
              type="submit"
            >
              Create release
            </button>
          </div>
        </form>
      </Dialog>
    )
  }

  {
    canCreateRelease && pageTone === 'default' && addon && (
      <form
        method="post"
        action={Astro.url.pathname}
        class="mt-6 rounded-2xl border border-red-200 bg-red-50 p-5"
        onsubmit={`return confirm(${JSON.stringify(`Delete ${addon.name}? This cannot be undone.`)})`}
      >
        <input type="hidden" name="action" value="delete-addon" />
        <input type="hidden" name="csrf_token" value={deleteCsrfToken} />
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold text-red-900">Delete addon</p>
            <p class="text-sm text-red-700">Delete this addon and all of its versions from the registry.</p>
          </div>
          <button
            class="inline-flex items-center justify-center rounded-xl bg-red-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-red-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"
            type="submit"
            name="action"
            value="delete-addon"
          >
            Delete addon
          </button>
        </div>
      </form>
    )
  }

</RootLayout>
