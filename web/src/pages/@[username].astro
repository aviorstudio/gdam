---
export const prerender = false;

import RootLayout from '../layouts/RootLayout.astro';
import Title from '../components/Title.astro';
import AddonList from '../components/AddonList.astro';
import { getSessionFromCookies, hasAuthCookies } from '../lib/auth';
import { orgsDto, orgsProfilesDto, profilesDto, releasesDto, addonsDto, usernamesDto } from '../lib/dtoService';
import { toRepoUrl } from '../lib/repo';
import { formatSemverTripletFromNullable } from '../lib/semver';
import { supabase } from '../lib/supabase';

type UsernameRecord = {
  name: string | null;
  user_id: string | null;
  org_id: string | null;
};

type OrgsProfileRecord = {
  org_id: string | null;
  admin: boolean | null;
};

type OwnerRecord = {
  link: string | null;
  bio: string | null;
};

type PublishOwner = {
  value: string;
  label: string;
  slug: string;
  profileId: string | null;
  orgId: string | null;
};

type AddonRecord = {
  id: string;
  name: string | null;
  repo: string | null;
  editor?: boolean | null;
  created_at: string | null;
};

type ReleaseRecord = {
  addon_id: string;
  major: number | null;
  minor: number | null;
  patch: number | null;
  tag: string | null;
  asset: string | null;
  created_at: string | null;
};

const safeDecodeURIComponent = (value: string) => {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const normalizeUsername = (value: string) => value.trim().toLowerCase();

const usernameParamRaw = Astro.params.username ?? '';
const usernameParam = safeDecodeURIComponent(usernameParamRaw);
const usernameNormal = normalizeUsername(usernameParam);

const session = hasAuthCookies(Astro.cookies) ? await getSessionFromCookies(Astro.cookies) : null;
const profileId = session?.user?.id ?? '';

let pageTone: 'default' | 'not-found' | 'error' = 'default';
let pageStatus = '';
let entityLabel = '';
let entitySlug = '';
let githubUserUrl = '';
let githubUserLabel = '';
let ownerBio = '';
let settingsHref = '';

let canCreateAddon = false;

const publishOwners: PublishOwner[] = [];

if (profileId) {
  const { data: profileUsernameRows, error: profileUsernameError } = await usernamesDto.getByUserId(supabase, profileId);
  if (!profileUsernameError) {
    const profileUsername = ((profileUsernameRows as UsernameRecord[] | null) ?? []).find((row) => row.user_id === profileId && row.name);
    if (profileUsername?.name) {
      publishOwners.push({
        value: `profile:${profileId}`,
        label: `@${profileUsername.name}`,
        slug: profileUsername.name,
        profileId,
        orgId: null,
      });
    }
  }

  const { data: membershipRows, error: membershipsError } = await orgsProfilesDto.listByProfileId(supabase, profileId);
  if (!membershipsError) {
    const adminOrgIds = ((membershipRows as OrgsProfileRecord[] | null) ?? [])
      .filter((row) => row.admin && row.org_id)
      .map((row) => row.org_id as string);

    if (adminOrgIds.length > 0) {
      const { data: orgUsernameRows, error: orgUsernameError } = await usernamesDto.listByOrgIds(supabase, adminOrgIds);
      if (!orgUsernameError) {
        for (const row of (orgUsernameRows as UsernameRecord[] | null) ?? []) {
          if (!row.org_id || !row.name) continue;
          publishOwners.push({
            value: `org:${row.org_id}`,
            label: `@${row.name}`,
            slug: row.name,
            profileId: null,
            orgId: row.org_id,
          });
        }
      }
    }
  }
}

let publishedAddons: Array<{
  addonLabel: string;
  addonHref?: string;
  metaLabel?: string;
  metaHref?: string;
  date: string;
}> = [];

if (!usernameNormal) {
  Astro.response.status = 404;
  pageTone = 'not-found';
  pageStatus = 'That user could not be found.';
} else {
  const { data: usernameRow, error: usernameError } = await usernamesDto.getByName(supabase, usernameNormal);

  if (usernameError) {
    Astro.response.status = 500;
    pageTone = 'error';
    pageStatus = usernameError.message;
  } else if (!usernameRow) {
    Astro.response.status = 404;
    pageTone = 'not-found';
    pageStatus = 'That user could not be found.';
  } else {
    const usernameRecord = usernameRow as UsernameRecord;
    const usernameDisplay = usernameRecord.name || usernameParam;

    const ownerProfileId = usernameRecord.user_id;
    const ownerOrgId = usernameRecord.org_id;

    if (ownerProfileId && ownerOrgId) {
      Astro.response.status = 500;
      pageTone = 'error';
      pageStatus = 'Username is assigned to multiple owners.';
    } else if (!ownerProfileId && !ownerOrgId) {
      Astro.response.status = 404;
      pageTone = 'not-found';
      pageStatus = 'That user could not be found.';
    } else {
      entityLabel = `@${usernameDisplay}`;
      entitySlug = encodeURIComponent(usernameDisplay);

      const { data: ownerData } = ownerOrgId
        ? await orgsDto.getById(supabase, ownerOrgId)
        : await profilesDto.getById(supabase, ownerProfileId ?? '');
      const ownerRecord = ownerData as OwnerRecord | null;
      githubUserUrl = ownerRecord?.link ?? '';
      githubUserLabel = githubUserUrl ? githubUserUrl.replace(/^https?:\/\//i, '').replace(/\/$/, '') : '';
      ownerBio = ownerRecord?.bio ?? '';

      canCreateAddon = publishOwners.length > 0;
      const canManageOwner = Boolean(
        (ownerProfileId && profileId && ownerProfileId === profileId) ||
        (ownerOrgId && publishOwners.some((owner) => owner.orgId === ownerOrgId))
      );
      settingsHref = canManageOwner ? `/settings/@${entitySlug}` : '';

      const { data: addonsData, error: addonsError } = ownerOrgId
        ? await addonsDto.listByOrgId(supabase, ownerOrgId)
        : await addonsDto.listByProfileId(supabase, ownerProfileId ?? '');

      if (addonsError) {
        Astro.response.status = 500;
        pageTone = 'error';
        pageStatus = addonsError.message;
      } else {
        const addons = (addonsData as AddonRecord[] | null) ?? [];

        const latestReleaseByAddonId = new Map<string, { version: string; releaseTag: string; createdAt: string }>();
        if (addons.length > 0) {
          const addonIds = addons.map((addon) => addon.id);
          const { data: versionRows, error: versionError } = await releasesDto.listByAddonIds(
            supabase,
            addonIds
          );
          if (versionError) {
            pageStatus = pageStatus || 'Unable to load addon versions.';
          } else {
            for (const row of (versionRows as ReleaseRecord[] | null) ?? []) {
              if (!latestReleaseByAddonId.has(row.addon_id)) {
                latestReleaseByAddonId.set(row.addon_id, {
                  version: formatSemverTripletFromNullable(row),
                  releaseTag: row.tag ?? '',
                  createdAt: row.created_at ?? '',
                });
              }
            }
          }
        }

        publishedAddons = addons.map((addon) => {
          const addonSlug = addon.name ?? '';
          const addonHref = addonSlug ? `/@${entitySlug}/${encodeURIComponent(addonSlug)}` : undefined;
          const latestRelease = latestReleaseByAddonId.get(addon.id);
          const repoUrl = addon.repo ? toRepoUrl(addon.repo) : '';
          const versionLabel = latestRelease?.version ? latestRelease.version : 'No versions';
          const treeUrl = latestRelease?.releaseTag ? `${repoUrl}/releases/tag/${encodeURIComponent(latestRelease.releaseTag)}` : '';

          return {
            addonLabel: addonSlug || 'Untitled addon',
            addonHref,
            metaLabel: versionLabel,
            metaHref: treeUrl || undefined,
            date: latestRelease?.createdAt || addon.created_at || '',
          };
        });
      }
    }
  }
}
---

<RootLayout>
  <Title
    title={pageTone === 'not-found' ? 'Not found' : entityLabel || `@${usernameParam}`}
    subtitle={pageTone === 'not-found'
      ? 'No user or organization owns that username.'
      : ownerBio || undefined}
    subtitleLink={pageTone !== 'not-found' && githubUserUrl
      ? { href: githubUserUrl, label: githubUserLabel, external: true }
      : undefined}
    subtitleLinkFirst
    actions={pageTone === 'default' ? [
      ...(canCreateAddon ? [{ href: `/create/@${entitySlug}`, label: 'Create addon' }] : []),
      ...(settingsHref ? [{ href: settingsHref, label: 'Settings' }] : []),
    ] : undefined}
  />

  <AddonList
    items={publishedAddons}
    status={pageStatus}
    tone={pageTone === 'error' ? 'error' : 'muted'}
    hideBodyWhenError
    emptyTitle={pageTone === 'not-found' ? 'No matching owner' : 'No addons yet'}
    emptySubtitle={pageTone === 'not-found'
      ? 'Double-check the username and try again.'
      : 'This account has not published any addons.'}
  />

</RootLayout>
